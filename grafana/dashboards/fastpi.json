{
    "title": "FastAPI Observability Dashboard",
    "tags": [
        "fastapi",
        "metrics",
        "logs"
    ],
    "timezone": "browser",
    "schemaVersion": 38,
    "refresh": "5s",
    "panels": [
        {
            "type": "timeseries",
            "title": "API Request Counts (Rates)",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 0
            },
            "targets": [
                {
                    "expr": "rate(request_count[1m])",
                    "legendFormat": "Root Requests",
                    "refId": "A"
                },
                {
                    "expr": "rate(demo_info_count[1m])",
                    "legendFormat": "Info Requests",
                    "refId": "B"
                },
                {
                    "expr": "rate(demo_error_count[1m])",
                    "legendFormat": "Error Requests",
                    "refId": "C"
                }
            ],
            "options": {
                "legend": {
                    "displayMode": "list",
                    "placement": "bottom"
                }
            }
        },
        {
            "type": "timeseries",
            "title": "Work Endpoint Duration (Seconds)",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 0
            },
            "targets": [
                {
                    "expr": "rate(demo_work_duration_seconds_sum[1m]) / rate(demo_work_duration_seconds_count[1m])",
                    "legendFormat": "Average Latency",
                    "refId": "A"
                }
            ]
        },
        {
            "type": "logs",
            "title": "Raw Application Logs (Loki)",
            "gridPos": {
                "h": 10,
                "w": 24,
                "x": 0,
                "y": 8
            },
            "targets": [
                {
                    "expr": "{job=\"app-logs\"} | json",
                    "refId": "A"
                }
            ],
            "options": {
                "showTime": true,
                "showLabels": false,
                "showCommonLabels": false,
                "wrapLogMessage": true
            }
        },
        {
            "type": "stat",
            "title": "Total Errors Logged",
            "gridPos": {
                "h": 5,
                "w": 24,
                "x": 0,
                "y": 18
            },
            "targets": [
                {
                    "expr": "count_over_time({job=\"app-logs\"} | json | levelname=\"ERROR\" [1m])",
                    "refId": "A"
                }
            ],
            "options": {
                "reduceOptions": {
                    "values": true,
                    "calcs": [
                        "sum"
                    ]
                },
                "colorMode": "background"
            }
        }
    ]
}