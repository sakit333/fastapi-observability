{
  "title": "FastAPI Logs (Loki)",
  "schemaVersion": 42,
  "refresh": "5s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "logs",
      "title": "All Logs",
      "datasource": {
        "type": "loki",
        "uid": "P8E80F9AEF21F6940"
      },
      "targets": [
        {
          "expr": "{job=\"app-logs\"}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Error Logs",
      "datasource": {
        "type": "loki",
        "uid": "P8E80F9AEF21F6940"
      },
      "targets": [
        {
          "expr": "count_over_time({job=\"app-logs\"} | json | levelname=\"ERROR\" [$__range])",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 10 }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total Warning Logs",
      "datasource": {
        "type": "loki",
        "uid": "P8E80F9AEF21F6940"
      },
      "targets": [
        {
          "expr": "count_over_time({job=\"app-logs\"} | json | levelname=\"WARNING\" [$__range])",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 10 }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Total Info Logs",
      "datasource": {
        "type": "loki",
        "uid": "P8E80F9AEF21F6940"
      },
      "targets": [
        {
          "expr": "count_over_time({job=\"app-logs\"} | json | levelname=\"INFO\" [$__range])",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 10 }
    },
    {
      "id": 5,
      "type": "logs",
      "title": "Error Logs Stream",
      "datasource": {
        "type": "loki",
        "uid": "P8E80F9AEF21F6940"
      },
      "targets": [
        {
          "expr": "{job=\"app-logs\"} | json | levelname=\"ERROR\"",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 15 }
    },
    {
      "id": 6,
      "type": "logs",
      "title": "Trace-linked Logs",
      "datasource": {
        "type": "loki",
        "uid": "P8E80F9AEF21F6940"
      },
      "targets": [
        {
          "expr": "{job=\"app-logs\"} | json | trace_id!=\"\"",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 15 }
    }
  ]
}