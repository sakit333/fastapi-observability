{
  "title": "FastAPI Metrics (Prometheus)",
  "schemaVersion": 38,
  "refresh": "5s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Request Rate (req/sec)",
      "targets": [
        {
          "expr": "rate(request_count_total[1m])",
          "legendFormat": "Total Requests",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "Endpoint Traffic",
      "targets": [
        {
          "expr": "rate(demo_info_count_total[1m])",
          "legendFormat": "Info",
          "refId": "A"
        },
        {
          "expr": "rate(demo_error_count_total[1m])",
          "legendFormat": "Error",
          "refId": "B"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "type": "stat",
      "title": "Total Requests",
      "targets": [
        {
          "expr": "request_count_total",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 }
    },
    {
      "type": "stat",
      "title": "Total Errors",
      "targets": [
        {
          "expr": "demo_error_count_total",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 }
    },
    {
      "type": "stat",
      "title": "Error Rate (%)",
      "targets": [
        {
          "expr": "rate(demo_error_count_total[1m]) / rate(request_count_total[1m]) * 100",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 }
    },
    {
      "type": "timeseries",
      "title": "Average Latency (seconds)",
      "targets": [
        {
          "expr": "rate(demo_work_duration_seconds_sum[1m]) / rate(demo_work_duration_seconds_count[1m])",
          "legendFormat": "Avg Latency",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 }
    },
    {
      "type": "timeseries",
      "title": "P95 Latency",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(demo_work_duration_seconds_bucket[1m]))",
          "legendFormat": "P95",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 }
    },
    {
      "type": "timeseries",
      "title": "CPU Usage",
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total[1m])",
          "legendFormat": "CPU",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 }
    },
    {
      "type": "timeseries",
      "title": "Memory Usage (Bytes)",
      "targets": [
        {
          "expr": "process_resident_memory_bytes",
          "legendFormat": "Memory",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 }
    },
    {
      "type": "timeseries",
      "title": "Payment Requests",
      "targets": [
        {
          "expr": "rate(payment_requests_total[1m])",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Order Requests",
      "targets": [
        {
          "expr": "rate(order_requests_total[1m])",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Payment Latency",
      "targets": [
        {
          "expr": "rate(payment_latency_seconds_sum[1m]) / rate(payment_latency_seconds_count[1m])",
          "legendFormat": "Avg Payment Latency",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Order Latency",
      "targets": [
        {
          "expr": "rate(order_latency_seconds_sum[1m]) / rate(order_latency_seconds_count[1m])",
          "legendFormat": "Avg Order Latency",
          "refId": "A"
        }
      ]
    }
  ]
}